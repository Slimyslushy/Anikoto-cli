#!/bin/sh
# anikoto-cli — watch anime in mpv via AniList + megaplay.buzz
# Dependencies: curl, fzf, jq, mpv

version="2.5.0"
megaplay="https://megaplay.buzz"
agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36"
mode="${ANI_CLI_MODE:-sub}"
player="${ANI_CLI_PLAYER:-}"
download_mode=0
ep_range=""
histfile="${XDG_STATE_HOME:-$HOME/.local/state}/anikoto-cli/history"
configfile="${XDG_CONFIG_HOME:-$HOME/.config}/anikoto-cli/config"

# ── download dir: built-in default < saved config < env var ─────────────────
download_dir="$PWD"
[ -f "$configfile" ] && . "$configfile" 2>/dev/null
[ -n "$ANI_CLI_DOWNLOAD_DIR" ] && download_dir="$ANI_CLI_DOWNLOAD_DIR"

# ── helpers ───────────────────────────────────────────────────────────────────
die()  { printf "\033[1;31m%s\033[0m\n" "$*" >&2; exit 1; }
info() { printf "\033[1;34m:: %s\033[0m\n" "$*" >&2; }
ok()   { printf "\033[1;32m✓ %s\033[0m\n" "$*" >&2; }

dep_ch() {
    for dep; do
        command -v "$dep" >/dev/null || die "missing dependency: $dep"
    done
}

launcher() {
    fzf --reverse --cycle --prompt "$1 > " --with-nth=1 --delimiter=$'\t'
}

detect_player() {
    [ -n "$player" ] && return
    command -v mpv  >/dev/null && player=mpv  && return
    command -v vlc  >/dev/null && player=vlc  && return
    [ -f "/Applications/IINA.app/Contents/MacOS/iina-cli" ] \
        && player="/Applications/IINA.app/Contents/MacOS/iina-cli" && return
    die "no player found — install mpv"
}

# ── help ──────────────────────────────────────────────────────────────────────
usage() {
    cat << HELP
usage: ${0##*/} [-h] [-V] [-d] [-v] [-c] [-D] [-m sub|dub] [-e NUM] [-o DIR] [query]

options:
  -e, --episode <n>     episode number or range (e.g. 3 or 1-12)
  -m, --mode <m>        sub or dub (default: sub)
  -o, --output <dir>    download directory; saved as the default — run with
                         just -o (no query) to update it without playing
  -d, --download        download instead of playing
  -c, --continue        resume from history
  -D, --delete          clear history
  -v, --vlc             use vlc
  -V, --version         print version
  -h, --help            this help

environment:
  ANI_CLI_MODE          default mode (sub/dub)
  ANI_CLI_PLAYER        player command
  ANI_CLI_DOWNLOAD_DIR  override download directory (takes priority over saved default)

after each episode: pick Next / Replay / Previous / Quit from the menu
HELP
    exit 0
}

# ── history ───────────────────────────────────────────────────────────────────
save_download_dir() {
    mkdir -p "$(dirname "$configfile")"
    esc=$(printf '%s' "$1" | sed "s/'/'\\\\''/g")
    printf "download_dir='%s'\n" "$esc" > "$configfile"
}

save_history() {
    mkdir -p "$(dirname "$histfile")"
    tmp=$(mktemp)
    grep -v "^${1}|" "$histfile" 2>/dev/null > "$tmp" || :
    printf '%s|%s|%s|%s|%s\n' "$1" "$2" "$3" "$4" "$5" | cat - "$tmp" > "$histfile"
    rm -f "$tmp"
}

load_history() {
    [ -f "$histfile" ] || die "no history found"
    awk -F'|' '{printf "%s — ep%s [%s]\t%s\t%s\t%s\n", $2,$3,$4,$1,$5,$4}' "$histfile" \
        | launcher "resume"
}

# ── search ────────────────────────────────────────────────────────────────────
search_anilist() {
    query=$(printf '%s' "$1" | sed 's/"/\\"/g')
    curl -s -X POST "https://graphql.anilist.co" \
        -H "Content-Type: application/json" \
        -d "{\"query\":\"query{Page(perPage:20){media(search:\\\"${query}\\\",type:ANIME,sort:SEARCH_MATCH){title{english romaji}idMal episodes}}}\"}" \
    | jq -r '
        .data.Page.media[] |
        (.title.english // .title.romaji) as $t |
        (.episodes // "?") as $e |
        (.idMal // "") as $id |
        "\($t)  (\($e) eps)\t\($id)\t\($e)"
    '
}

# ── sources ───────────────────────────────────────────────────────────────────
# outputs:
#   stream\t<url>
#   sub\t<label>\t<url>
get_sources() {
    mal_id=$1 ep=$2 lang=$3

    html=$(curl -s -A "$agent" -H "Referer: ${megaplay}/" \
        "${megaplay}/stream/mal/${mal_id}/${ep}/${lang}")

    id=$(printf '%s' "$html" | grep -oE 'data-id="[0-9]+"' | grep -oE '[0-9]+' | head -1)
    [ -z "$id" ] && return 1

    curl -s -A "$agent" -H "Referer: ${megaplay}/" \
        "${megaplay}/stream/getSources?id=${id}" \
    | jq -r '
        ( if .sources | type == "array" then .sources[0].file
          elif .sources | type == "object" then .sources.file
          else "" end
        ) as $url
        | (if $url != "" then "stream\t\($url)" else empty end),

        ( ( ( if (.tracks    | length // 0) > 0 then .tracks
              elif (.captions  | length // 0) > 0 then .captions
              elif (.subtitles | length // 0) > 0 then .subtitles
              else [] end
            )[] ) |
          select((.file // .src // .url) != null) |
          select((.kind // .type // "") | ascii_downcase |
                 test("caption|subtitle|sub|^$")) |
          "sub\t\(.label // .title // "Unknown")\t\(.file // .src // .url)"
        )
    ' 2>/dev/null
}

get_sub_url() {
    printf '%s' "$1" | awk -F'\t' '
        /^sub/ {
            label = tolower($2)
            if (!first) first = $3
            if (label ~ /^english[ \t]*$/) {
                if (score < 3) { best = $3; score = 3 }
            } else if (label ~ /eng/ && label !~ /sign|song/) {
                if (score < 2) { best = $3; score = 2 }
            } else if (label ~ /eng/) {
                if (score < 1) { best = $3; score = 1 }
            }
        }
        END { print (best ? best : first) }
    '
}

# ── playback ──────────────────────────────────────────────────────────────────
play_episode() {
    url=$1 title=$2 sub=$3

    if [ "$download_mode" = 1 ]; then
    mkdir -p "$download_dir"

    out="${download_dir}/$(printf '%s' "$title" | tr ' /' '_-' | tr -dc 'A-Za-z0-9_.-').mp4"

    info "downloading to: $out"

    ffmpeg \
        -user_agent "$agent" \
        -headers "Referer: ${megaplay}/\r\n" \
        -i "$url" \
        -c copy \
        -y \
        "$out"

    [ $? -eq 0 ] && ok "saved: $out"
    return
fi

    case "$player" in
        *vlc*)
            set -- --http-referrer="${megaplay}/"
            [ -n "$sub" ] && set -- "$@" --sub-file="$sub"
            $player "$@" "$url"
            ;;
        *iina*)
            set -- --mpv-referrer="${megaplay}/"
            [ -n "$sub" ] && set -- "$@" --mpv-sub-file="$sub"
            $player "$@" "$url"
            ;;
        *)
            set -- --referrer="${megaplay}/" --force-media-title="$title"
            [ -n "$sub" ] && set -- "$@" --sub-file="$sub"
            $player "$@" "$url"
            ;;
    esac
}

# ── post-episode prompt ───────────────────────────────────────────────────────
ep_prompt() {
    sel=$(printf 'Next Episode\tnext\nReplay Episode\treplay\nPrevious Episode\tprev\nQuit\tquit\n' \
        | launcher "episode ${1}/${2:-?}")
    action=$(printf '%s' "$sel" | cut -f2)
    printf '%s' "${action:-quit}"
}

# ── main ──────────────────────────────────────────────────────────────────────
main() {
    dep_ch curl fzf jq ffmpeg
    detect_player

    query='' from_history=0 output_set=0

    while [ $# -gt 0 ]; do
        case $1 in
            -h|--help)               usage ;;
            -V|--version)            printf '%s\n' "$version"; exit 0 ;;
            -d|--download)           download_mode=1 ;;
            -v|--vlc)                player=vlc ;;
            -c|--continue)           from_history=1 ;;
            -D|--delete)             rm -f "$histfile"; printf 'history cleared\n'; exit 0 ;;
            -m|--mode)               shift; mode=$1 ;;
            -e|--episode|-r|--range) shift; ep_range=$1 ;;
            -o|--output)             shift; download_dir=$1; output_set=1 ;;
            --dub)                   mode=dub ;;
            --sub)                   mode=sub ;;
            -*)                      die "unknown option: $1" ;;
            *)                       query="${query:+$query }$1" ;;
        esac
        shift
    done

    # ── download directory update ─────────────────────────────────────────────
    if [ "$output_set" = 1 ]; then
        mkdir -p "$download_dir" || die "could not create directory: $download_dir"
        save_download_dir "$download_dir"
        if [ -z "$query" ] && [ "$from_history" = 0 ]; then
            ok "default download directory updated: $download_dir"
            exit 0
        fi
    fi

    # ── series selection ──────────────────────────────────────────────────────
    if [ "$from_history" = 1 ]; then
        raw=$(load_history)
        [ -z "$raw" ] && die "nothing selected"
        mal_id=$(   printf '%s' "$raw" | cut -f2)
        total_eps=$(printf '%s' "$raw" | cut -f3)
        mode=$(     printf '%s' "$raw" | cut -f4)
        series_title=$(awk -F'|' -v m="$mal_id" '$1==m{print $2;exit}' "$histfile")
        last_ep=$(  awk -F'|' -v m="$mal_id" '$1==m{print $3;exit}' "$histfile")
        [ -z "$ep_range" ] && ep_range="${last_ep}-${last_ep}"
    else
        [ -z "$query" ] && printf 'search anime: ' && read -r query
        [ -z "$query" ] && die "no query given"

        results=$(search_anilist "$query")
        [ -z "$results" ] && die "no results for: $query"

        selected=$(printf '%s' "$results" | launcher "select anime")
        [ -z "$selected" ] && die "nothing selected"

        series_title=$(printf '%s' "$selected" | cut -f1 | sed 's/  ([0-9?]* eps)$//')
        mal_id=$(      printf '%s' "$selected" | cut -f2)
        total_eps=$(   printf '%s' "$selected" | cut -f3)

        { [ -z "$mal_id" ] || [ "$mal_id" = 'null' ]; } \
            && die "no MAL id for '$series_title' — can't stream"
    fi

    info "$series_title  (mal:$mal_id  eps:$total_eps  $mode)"

    # ── episode selection ─────────────────────────────────────────────────────
    if [ -z "$ep_range" ]; then
        if [ "$total_eps" = '?' ] || [ -z "$total_eps" ]; then
            printf 'episode (or range, e.g. 1-12): '
            read -r ep_range
            [ -z "$ep_range" ] && die "no episode given"
        else
            ep_num=$(seq 1 "$total_eps" \
                | awk '{printf "episode %s\t%s\n",$1,$1}' \
                | launcher "select episode" \
                | cut -f2)
            [ -z "$ep_num" ] && die "nothing selected"
            ep_start=$ep_num ep_end=$ep_num
        fi
    fi

    if [ -z "${ep_start:-}" ]; then
        ep_range=$(printf '%s' "$ep_range" | tr ' ' '-')
        ep_start=$(printf '%s' "$ep_range" | cut -d- -f1)
        ep_end=$(  printf '%s' "$ep_range" | cut -d- -f2)
    fi

    # ── playback loop ─────────────────────────────────────────────────────────
    ep_num=$ep_start
    while :; do
        [ "$ep_num" -lt 1 ] && ep_num=1
        [ -n "$total_eps" ] && [ "$total_eps" != '?' ] \
            && [ "$ep_num" -gt "$total_eps" ] && ok "end of series" && break
        [ "$download_mode" = 1 ] && [ "$ep_num" -gt "$ep_end" ] && break

        label="${series_title} — episode ${ep_num} [${mode}]"
        info "→ $label"

        sources=$(get_sources "$mal_id" "$ep_num" "$mode")

        if [ -z "$sources" ] || ! printf '%s' "$sources" | grep -q '^stream'; then
            other=$([ "$mode" = dub ] && printf sub || printf dub)
            info "no $mode stream — trying $other"
            sources=$(get_sources "$mal_id" "$ep_num" "$other")
            { [ -z "$sources" ] || ! printf '%s' "$sources" | grep -q '^stream'; } \
                && die "no stream for episode $ep_num"
            printf '\033[1;33mwarning: using %s\033[0m\n' "$other" >&2
        fi

        stream=$(printf '%s' "$sources" | awk -F'\t' '/^stream/{print $2;exit}')
        [ -z "$stream" ] && die "could not parse stream url"

        sub=$(get_sub_url "$sources")

        n_subs=$(printf '%s' "$sources" | grep -c '^sub' || :)
        [ "$n_subs" -gt 0 ] && ok "$n_subs subtitle track(s)" \
            && printf '%s' "$sources" | awk -F'\t' '/^sub/{printf "   %s\n",$2}' >&2

        play_episode "$stream" "$label" "$sub"
        save_history "$mal_id" "$series_title" "$ep_num" "$mode" "${total_eps:-?}"

        [ "$download_mode" = 1 ] && { ep_num=$((ep_num+1)); continue; }

        action=$(ep_prompt "$ep_num" "$total_eps")
        case $action in
            next)   ep_num=$((ep_num+1)) ;;
            prev)   ep_num=$((ep_num-1)) ;;
            replay) : ;;
            quit)   break ;;
        esac
    done

    ok "done"
}

main "$@"
